# Port and Host for local server
PORT=8000
HOST=127.0.0.1

# LWA (Login with Amazon) OAuth Credentials
LWA_CLIENT_ID=your_lwa_client_id_here
LWA_CLIENT_SECRET=your_lwa_client_secret_here
LWA_REFRESH_TOKEN=your_lwa_refresh_token_here

# Selected Amazon Ads Profile ID
AMAZON_ADS_PROFILE_ID=your_profile_id_here
# Region for Amazon Ads API: na (North America), eu (Europe), fe (Far East)
AMAZON_ADS_REGION=na

# Local database url
DATABASE_PATH=./data/aaoe.db

# Encryption Key (Must be 32 URL-safe base64-encoded bytes)
# Run `python3 -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"` to generate one
ENCRYPTION_KEY=SDRndjNmOWRzZjhuMzJkNDU2Nzg5MGFiY2RlZmdoaWo=
